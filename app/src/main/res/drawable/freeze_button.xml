<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <stroke android:width="2dp" android:color="#f54300" />
                </shape>
            </item>
            <item android:bottom="6dp" android:left="6dp" android:right="6dp" android:top="6dp">
                <shape android:shape="oval">
                    <solid android:color="#ff4500" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <stroke android:width="2dp" android:color="#757575" />
                </shape>
            </item>
            <item android:bottom="6dp" android:left="6dp" android:right="6dp" android:top="6dp">
                <shape android:shape="oval">
                    <solid android:color="#0a0a0a" />
                    <stroke android:width="1dp" android:color="#3e3e3e" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>