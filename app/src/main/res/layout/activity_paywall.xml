<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header: Close Button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_clear"
                app:tint="#8E8E93"
                android:contentDescription="Close screen" />
        </RelativeLayout>

        <!-- Title and Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/puritan_bold"
            android:gravity="center"
            android:text="Unlock Color Scan Pro"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_mono_regular"
            android:gravity="center"
            android:text="Identify, match and save colors without ads and limits."
            android:textColor="#8E8E93"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="36dp" />

        <!-- Gói Cước Options Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="36dp">

            <!-- Gói 1 Tháng -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMonthly"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="12dp"
                app:strokeColor="#2C2C2E"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvPriceMonthly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="đ29,000"
                        android:textColor="#FFB300"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gói 1 Năm -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardYearly"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="12dp"
                app:strokeColor="#FFB300"
                app:strokeWidth="2dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yearly"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvPriceYearly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="đ149,000"
                        android:textColor="#FFB300"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#FFB300"
                        android:textColor="#0C0C0C"
                        android:text="3 DAYS FREE"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="1dp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gói Vĩnh Viễn -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLifetime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="12dp"
                app:strokeColor="#2C2C2E"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lifetime"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvPriceLifetime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="đ299,000"
                        android:textColor="#FFB300"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Pro Features List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="48dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓ Ad-free experience (Remove all Ads)"
                android:textColor="#EAEAEA"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/roboto_mono_regular" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓ Unlimited colors saved to history"
                android:textColor="#EAEAEA"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/roboto_mono_regular" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓ Maximum precision in matching algorithms"
                android:textColor="#EAEAEA"
                android:textSize="14sp"
                android:fontFamily="@font/roboto_mono_regular" />

        </LinearLayout>

        <!-- Main Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubscribeAction"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start 3-Day Free Trial"
            android:textColor="#0C0C0C"
            android:textStyle="bold"
            app:backgroundTint="#FFB300"
            app:cornerRadius="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Secondary Links -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <TextView
                android:id="@+id/btnRestore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restore Purchase"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/roboto_mono_regular" />
            <TextView
                android:id="@+id/btnTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Terms &amp; Privacy Policy"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:fontFamily="@font/roboto_mono_regular" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
