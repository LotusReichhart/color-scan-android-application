<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#161616"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#2C2C2E"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <View
            android:id="@+id/colorPreview"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_color_preview_circle" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvColorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_mono_regular"
                android:textColor="#EAEAEA"
                android:textSize="15sp"
                android:textStyle="bold"
                app:fontFamily="@font/roboto_mono_regular" />

            <TextView
                android:id="@+id/tvColorDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/roboto_mono_regular"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                app:fontFamily="@font/roboto_mono_regular" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnCopy"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Copy color"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_copy"
            app:tint="#8E8E93" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
