<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C0C0C"
    tools:context=".feature.scan.ScanFragment">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="64dp"
        app:implementationMode="compatible"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/scanGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/scan_grid_selector"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <FrameLayout
        android:id="@+id/targetContainer"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/ic_scan_corners_inner"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView">

        <ImageView
            android:id="@+id/ivTargetPoint"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_crosshair" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/badgeFrozen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/badge_frozen_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView"
        tools:visibility="visible">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/badge_dot" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="FROZEN"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Widget hiển thị kết quả nhận diện màu sắc -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/colorResultCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_color_result_card"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnFreeze"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Vòng tròn hiển thị màu sắc -->
        <View
            android:id="@+id/colorPreviewCircle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_color_preview_circle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Tên màu sắc -->
        <TextView
            android:id="@+id/tvColorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:ellipsize="end"
            android:fontFamily="@font/puritan_bold"
            android:maxLines="1"
            android:text="Sunset Orange"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnCopy"
            app:layout_constraintStart_toEndOf="@id/colorPreviewCircle"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Mã HEX -->
        <TextView
            android:id="@+id/tvColorHex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/roboto_mono_regular"
            android:text="HEX: #FF4500"
            android:textColor="#8E8E93"
            android:textSize="14sp"
            app:fontFamily="@font/roboto_mono_regular"
            app:layout_constraintEnd_toStartOf="@id/btnCopy"
            app:layout_constraintStart_toEndOf="@id/colorPreviewCircle"
            app:layout_constraintTop_toBottomOf="@id/tvColorName" />

        <!-- Mã RGB -->
        <TextView
            android:id="@+id/tvColorRgb"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/roboto_mono_regular"
            android:text="RGB: 255, 69, 0"
            android:textColor="#8E8E93"
            android:textSize="14sp"
            app:fontFamily="@font/roboto_mono_regular"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCopy"
            app:layout_constraintStart_toEndOf="@id/colorPreviewCircle"
            app:layout_constraintTop_toBottomOf="@id/tvColorHex" />

        <!-- Nút Copy -->
        <ImageView
            android:id="@+id/btnCopy"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_copy"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageButton
        android:id="@+id/btnFreeze"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/freeze_button"
        android:contentDescription="Freeze scan"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/btnFlash"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_flash_off"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnZoomOut"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_zoom_out" />

        <TextView
            android:id="@+id/tvZoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:fontFamily="@font/roboto_mono_regular"
            android:text="1.0x"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:fontFamily="@font/roboto_mono_regular" />

        <ImageView
            android:id="@+id/btnZoomIn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_zoom_in" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>